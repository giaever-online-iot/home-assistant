#!/bin/sh
set -e
# Validate the new snap config before applying it (spec §13).  The validate
# subcommand does not call docker, so it works even before interfaces are
# connected.  A non-zero exit aborts the hook and rejects the snap set
# atomically, leaving the container untouched.
"$SNAP/bin/launcher" validate

# Re-apply configuration by restarting the launcher daemon, which reconciles
# the Home Assistant container to the (possibly changed) snap config. Reconcile
# is idempotent: a spec-hash label means an unchanged config is a no-op.
if snapctl services "${SNAP_INSTANCE_NAME}.daemon" >/dev/null 2>&1; then
    snapctl restart "${SNAP_INSTANCE_NAME}.daemon"
fi
